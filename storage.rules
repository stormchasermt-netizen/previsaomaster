rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Define administratos no storage
    function isAdmin() {
      return request.auth.token.email in ['stormchasermt@gmail.com', 'admin@previsaomaster.com', 'augustof12010@gmail.com'];
    }

    // Permite que qualquer pessoa leia as imagens (necessário para os jogadores verem os mapas).
    // Permite que QUALQUER USUÁRIO AUTENTICADO (logado) envie/atualize imagens.
    // O controle de quem pode acessar o painel de upload é feito na interface do aplicativo.
    match /events/{eventId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Imagens de rastros de tornados (GeoTIFF/fotos) — apenas o dono ou admin pode escrever
    match /tornado_tracks/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    // Arquivos CSV de sondagem brutos (Sondagens Raw)
    match /sounding_csvs/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    // Fotos/vídeos de relatos de tempestade (vento, granizo, tornado)
    match /storm_reports/{reportId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Permite leitura pública de todas as imagens históricas de radar (IPMet/Bauru/Presidente Prudente)
    match /ipmet-bauru/{allPaths=**} {
      allow read: if true;
    }
    // Permite leitura pública de todas as imagens históricas de radar (Backup Geral)
    match /radar_backup/{allPaths=**} {
      allow read: if true;
    }
    // Mídias adicionadas pelos meteorologistas nos fóruns/mapas dos rastros
    match /track_comments_media/{trackId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
