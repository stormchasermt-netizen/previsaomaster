rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permite que qualquer pessoa leia as imagens (necessário para os jogadores verem os mapas).
    // Permite que apenas usuários autenticados COM E-MAIL DE ADMIN enviem/atualizem as imagens.
    match /events/{eventId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in ['stormchasermt@gmail.com', 'admin@previsaomaster.com'];
    }
  }
}
