PORT=8080
GCS_BUCKET=radar_ao_vivo_2
CRON_SECRET=super_secret_token_para_invocacao_segura

# CPTEC: buscar imagens desde agora até N minutos atrás (varredura minuto a minuto + snap por radar)
SYNC_WINDOW_MINUTES=60
# Se false, só grava PPI (ppicz); se true ou omitido, grava também Doppler (ppivr) como {ts12}-ppivr.png
# CPTEC_FETCH_DOPPLER=true

# /cleanup apaga ficheiros cujo timestamp no nome (YYYYMMDDHHmm) é mais antigo que isto
RETENTION_MINUTES=60

# Opcional (se omitido usa DEFAULT_SYNC_SLUGS):
# SYNC_SLUGS=chapeco,santiago,ipmet-bauru,climatempo-poa

# Jobs automáticos ao arrancar o processo (sync + cleanup em ciclo). Default: ligado.
# ENABLE_AUTO_JOBS=true
# Intervalo entre ciclos (ms). Default 300000 = 5 minutos.
# AUTO_JOB_INTERVAL_MS=300000
# Atraso antes do 1.º ciclo (ms), útil no Cloud Run. Default 8000.
# AUTO_JOB_START_DELAY_MS=8000

# Google Cloud credenciais locais (em Cloud Run o Workload Identity cuida disto):
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/absoluto/para/service-account.json
